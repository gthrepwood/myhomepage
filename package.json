{
  "name": "myhomepage",
  "version": "1.0.0",
  "description": "Simple homepage app with customizable application buttons",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node test/test-api.js && node test/test-settings.js",
    "setup-npm": "npm config set prefix ~ --global",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "build:docker": "docker build -t myhomepage:latest .",
    "publish:docker": "npm run build:docker && docker push myhomepage:latest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  }
}
