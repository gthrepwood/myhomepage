{
  "name": "myhomepage",
  "version": "1.1.0",
  "description": "Simple homepage app with customizable application buttons",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node test/test-api.js && node test/test-settings.js",
    "setup-npm": "npm config set prefix ~ --global",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "build:docker": "docker build -t myhomepage:latest .",
    "publish:docker": "npm run build:docker && docker tag myhomepage:latest gthrepwood/myhomepage:latest && docker push gthrepwood/myhomepage:latest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  }
}
